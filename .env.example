# Copy to .env and fill in real values. .env is gitignored — never commit it.

POSTGRES_PASSWORD=change-me
# Shared secret required on every backend POST endpoint (X-Api-Key header).
API_KEY=change-me
# Comma-separated list of origins the backend's CORS policy allows.
# Include both localhost and 127.0.0.1 forms — CORS treats them as distinct
# origins even though they're the same machine.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
